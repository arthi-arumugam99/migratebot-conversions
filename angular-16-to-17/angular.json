{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "angular-16-crud": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application", // MIGRATED: Angular 17 — replaced browser builder with application builder (esbuild-based)
          "options": {
            "outputPath": "dist/angular-16-crud",
            "index": "src/index.html",
            "browser": "src/main.ts", // MIGRATED: Angular 17 — renamed "main" to "browser" for application builder
            "polyfills": [
              "zone.js" // MIGRATED: Angular 17 — polyfills already in array format, no change needed
            ],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              "src/favicon.ico",
              "src/assets"
            ],
            "styles": [
              "src/styles.css"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kb",
                  "maximumError": "1mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "2kb",
                  "maximumError": "4kb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              // MIGRATED: Angular 17 — removed buildOptimizer, vendorChunk, namedChunks (not supported by application builder)
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "angular-16-crud:build:production" // MIGRATED: Angular 17 — renamed browserTarget to buildTarget
            },
            "development": {
              "buildTarget": "angular-16-crud:build:development" // MIGRATED: Angular 17 — renamed browserTarget to buildTarget
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "angular-16-crud:build" // MIGRATED: Angular 17 — renamed browserTarget to buildTarget
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "tsconfig.spec.json",
            "assets": [
              "src/favicon.ico",
              "src/assets"
            ],
            "styles": [
              "src/styles.css"
            ],
            "scripts": []
          }
        }
      }
    }
  }
}